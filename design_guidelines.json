  "universal_guidelines": {
    "accessibility": "Ensure text contrast ratio of 4.5:1. All images must have alt text. Interactive elements must be keyboard focusable.",
    "testing": "All interactive elements (buttons, links, inputs) MUST have a data-testid attribute in kebab-case (e.g., 'book-now-button', 'car-card-thar').",
    "motion": "Use smooth transitions (duration-300 ease-in-out) for hover states. No heavy parallax on mobile. Use simple fade-in for section entry.",
    "responsive": "Mobile-first. Stack columns on mobile, 2 cols on tablet, 3-4 on desktop. Touch targets min 44px."
  },
  "instructions_to_main_agent": [
    "Build a single-page React app (App.js) with smooth scroll sections.",
    "Use Tailwind for all styling. Avoid custom CSS unless necessary for animations.",
    "Use Lucide React for icons.",
    "Mock the booking flow: Clicking 'Book' opens WhatsApp with a pre-filled message: 'Hi Big Wheels, I want to book [Car Name] for dates...'.",
    "Implement the Sticky Header that changes style on scroll (transparent to white/shadow).",
    "Ensure the 'Car Listing' section filters or sorts as requested (Low to High Price default)."
