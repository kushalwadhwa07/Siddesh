{
  "identity": {
    "name": "E1",
    "tone": "Anti-AI, Bold, High-Conversion",
    "mission": "Create a car rental landing page that feels like a premium travel magazine, not a template."
  },
  "project_context": {
    "name": "Big Wheels Car Rentals",
    "type": "Landing Page",
    "target_audience": "Tourists in Goa (Mobile-first)",
    "primary_goal": "WhatsApp Bookings & Calls"
  },
  "theme": {
    "mode": "light",
    "philosophy": "Tropical Modernism. Clean white surfaces, lush green accents, and sharp typography."
  },
  "typography": {
    "font_family": {
      "headings": "Outfit, sans-serif",
      "body": "Plus Jakarta Sans, sans-serif"
    },
    "scale": {
      "h1": "text-4xl md:text-6xl font-bold tracking-tight",
      "h2": "text-3xl md:text-5xl font-semibold tracking-tight",
      "h3": "text-2xl md:text-3xl font-semibold",
      "body": "text-base md:text-lg leading-relaxed text-gray-600",
      "caption": "text-sm font-medium tracking-wide uppercase text-gray-500"
    },
    "installation": "Import from Google Fonts: https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
  },
  "colors": {
    "palette": {
      "background": {
        "primary": "#FFFFFF",
        "secondary": "#F8FAFC",
        "tertiary": "#F1F5F9"
      },
      "text": {
        "primary": "#111827",
        "secondary": "#4B5563",
        "muted": "#9CA3AF",
        "inverse": "#FFFFFF"
      },
      "brand": {
        "primary": "#10B981",
        "primary_hover": "#059669",
        "accent": "#F59E0B"
      },
      "semantic": {
        "success": "#10B981",
        "error": "#EF4444",
        "warning": "#F59E0B",
        "info": "#3B82F6"
      }
    },
    "usage_rules": {
      "gradients": "Use subtle gradients only on buttons or specific hero overlays. No full-screen gradients.",
      "shadows": "soft-shadow-lg: 0 10px 40px -10px rgba(0,0,0,0.08)",
      "whatsapp_button": "bg-[#25D366] hover:bg-[#128C7E] text-white"
    }
  },
  "spacing_layout": {
    "container": "max-w-7xl mx-auto px-4 sm:px-6 lg:px-8",
    "section_padding": "py-16 md:py-24",
    "grid_system": {
      "cars": "grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 md:gap-8",
      "features": "grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12"
    },
    "border_radius": {
      "cards": "rounded-2xl",
      "buttons": "rounded-full"
    }
  },
  "components": {
    "header": {
      "style": "Sticky, Glassmorphism (white/90 backdrop-blur-md)",
      "elements": ["Logo (Left)", "Nav Links (Hidden Mobile/Visible Desktop)", "Call CTA (Right)"]
    },
    "hero": {
      "layout": "Split (Text Left, Image Right) or Centered with Background Overlay",
      "content": ["Headline: 'Explore Goa on Your Terms'", "Subhead: 'Premium Self-Drive Cars from ₹999/day'", "Primary CTA: 'Book via WhatsApp'", "Trust Badges: 'Zero Deposit Options', '24/7 Support'"]
    },
    "floating_whatsapp": {
      "position": "fixed bottom-6 right-6 z-50",
      "style": "w-14 h-14 md:w-16 md:h-16 rounded-full shadow-xl flex items-center justify-center bg-[#25D366] hover:scale-110 transition-transform duration-300",
      "icon": "MessageCircle (Lucide)"
    },
    "car_card": {
      "style": "Minimalist, White Bg, Light Shadow Hover",
      "elements": ["Image (Top, Aspect 4:3)", "Title (Bold)", "Specs (Seats, Fuel, Trans)", "Price (Highlighted)", "Book Button (Full Width)"]
    },
    "testimonials": {
      "style": "Carousel or Masonry Grid",
      "card_style": "bg-gray-50 p-6 rounded-xl border border-gray-100"
    }
  },
